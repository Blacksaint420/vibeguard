{
  "name": "vibeguard",
  "version": "0.1.0",
  "description": "Local-first AI security CLI framework for developer findings and GRC risk evidence.",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "author": "VibeGuard maintainers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blacksaint420/vibeguard.git"
  },
  "homepage": "https://github.com/Blacksaint420/vibeguard#readme",
  "bugs": {
    "url": "https://github.com/Blacksaint420/vibeguard/issues"
  },
  "keywords": [
    "ai-security",
    "aibom",
    "agent-security",
    "llm-security",
    "appsec",
    "sast",
    "sarif",
    "owasp-llm",
    "cli"
  ],
  "bin": {
    "vibeguard": "./dist/packages/cli/src/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SUPPORT.md",
    "CHANGELOG.md",
    "docs/agent-capability-graph.md",
    "docs/ai-bom.md",
    "docs/ci.md",
    "docs/configuration.md",
    "docs/dependency-security.md",
    "docs/enterprise-readiness.md",
    "docs/getting-started.md",
    "docs/pre-commit.md",
    "docs/releasing.md",
    "docs/repository-management.md",
    "docs/rules.md",
    "docs/security-model.md",
    "schemas",
    "examples/policies",
    "action.yml",
    "vibeguard.yml.example"
  ],
  "workspaces": [
    "packages/cli",
    "packages/core",
    "packages/scanners",
    "packages/output"
  ],
  "scripts": {
    "benchmark:aibom": "node scripts/benchmark-aibom.mjs",
    "build": "node --no-warnings scripts/build.mjs",
    "prepack": "npm run build",
    "test": "node --test tests/*.test.ts",
    "vibeguard": "node packages/cli/src/index.ts",
    "vibeguard:dist": "node dist/packages/cli/src/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
