{
  "name": "vibeguard",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "vibeguard",
      "version": "0.1.0",
      "workspaces": [
        "packages/cli",
        "packages/core",
        "packages/scanners",
        "packages/output"
      ],
      "bin": {
        "vibeguard": "packages/cli/src/index.ts"
      },
      "engines": {
        "node": ">=25"
      }
    },
    "node_modules/@vibeguard/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@vibeguard/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@vibeguard/output": {
      "resolved": "packages/output",
      "link": true
    },
    "node_modules/@vibeguard/scanners": {
      "resolved": "packages/scanners",
      "link": true
    },
    "packages/cli": {
      "name": "@vibeguard/cli",
      "version": "0.1.0",
      "bin": {
        "vibeguard": "src/index.ts"
      }
    },
    "packages/core": {
      "name": "@vibeguard/core",
      "version": "0.1.0"
    },
    "packages/output": {
      "name": "@vibeguard/output",
      "version": "0.1.0"
    },
    "packages/scanners": {
      "name": "@vibeguard/scanners",
      "version": "0.1.0"
    }
  }
}
